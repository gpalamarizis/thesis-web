# --- Required ---
DATABASE_URL=postgres://user:pass@host:5432/thesis
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# --- Server ---
PORT=3000

# --- Frontend URL (for CORS εάν θελήσεις να το περιορίσεις) ---
FRONTEND_URL=https://thesis-frontend.gpal.workers.dev

# --- Cloudflare R2 (case_documents) ---
# Βρίσκονται στο Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thesis-documents
